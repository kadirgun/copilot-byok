{
  "name": "copilot-byok",
  "displayName": "Copilot BYOK",
  "description": "Add custom OpenAI and Anthropic providers to VS Code Copilot",
  "icon": "copilot-byok.png",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "enabledApiProposals": [
    "languageModelSystem"
  ],
  "categories": [
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "copilot-byok",
          "title": "Copilot BYOK",
          "icon": "media/copilot-byok-view.svg"
        }
      ]
    },
    "views": {
      "copilot-byok": [
        {
          "id": "copilot-byok.formView",
          "name": "Form",
          "type": "webview",
          "visibility": "hidden"
        }
      ]
    },
    "commands": [
      {
        "command": "copilot-byok.addProvider",
        "title": "Copilot BYOK: Add Provider"
      },
      {
        "command": "copilot-byok.editProvider",
        "title": "Copilot BYOK: Edit Provider"
      },
      {
        "command": "copilot-byok.deleteProvider",
        "title": "Copilot BYOK: Delete Provider"
      },
      {
        "command": "copilot-byok.addModel",
        "title": "Copilot BYOK: Add Model"
      },
      {
        "command": "copilot-byok.deleteModel",
        "title": "Copilot BYOK: Delete Model"
      },
      {
        "command": "copilot-byok.editModel",
        "title": "Copilot BYOK: Edit Model"
      }
    ],
    "configuration": {
      "title": "Copilot BYOK",
      "properties": {}
    },
    "languageModelChatProviders": [
      {
        "vendor": "copilot-byok",
        "displayName": "BYOK",
        "configuration": {
          "type": "object",
          "properties": {
            "groupId": {
              "type": "string",
              "description": "Group ID for this provider configuration"
            }
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "lodash.kebabcase": "^4.1.1",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/lodash.kebabcase": "^4.1.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}