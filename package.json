{
  "name": "copilot-byok",
  "displayName": "Copilot BYOK",
  "description": "Add custom OpenAI and Anthropic providers to VS Code Copilot",
  "icon": "images/copilot-byok.png",
  "version": "0.0.4",
  "publisher": "kadirgun",
  "repository": {
    "url": "https://github.com/kadirgun/copilot-byok",
    "type": "git"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "copilot",
    "byok",
    "openai",
    "anthropic",
    "provider",
    "ai",
    "language-model"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "copilot-byok",
          "title": "Copilot BYOK",
          "icon": "images/copilot-byok.png"
        }
      ]
    },
    "views": {
      "copilot-byok": [
        {
          "id": "copilot-byok.formView",
          "name": "Form",
          "type": "webview",
          "visibility": "hidden",
          "icon": "images/copilot-byok.png"
        }
      ]
    },
    "commands": [
      {
        "command": "copilot-byok.addProvider",
        "title": "Copilot BYOK: Add Provider",
        "icon": "images/copilot-byok.png"
      },
      {
        "command": "copilot-byok.editProvider",
        "title": "Copilot BYOK: Edit Provider",
        "icon": "images/copilot-byok.png"
      },
      {
        "command": "copilot-byok.deleteProvider",
        "title": "Copilot BYOK: Delete Provider",
        "icon": "images/copilot-byok.png"
      },
      {
        "command": "copilot-byok.addModel",
        "title": "Copilot BYOK: Add Model",
        "icon": "images/copilot-byok.png"
      },
      {
        "command": "copilot-byok.deleteModel",
        "title": "Copilot BYOK: Delete Model",
        "icon": "images/copilot-byok.png"
      },
      {
        "command": "copilot-byok.editModel",
        "title": "Copilot BYOK: Edit Model",
        "icon": "images/copilot-byok.png"
      }
    ],
    "configuration": {
      "title": "Copilot BYOK",
      "properties": {}
    },
    "languageModelChatProviders": [
      {
        "vendor": "copilot-byok",
        "displayName": "BYOK",
        "configuration": {
          "type": "object",
          "properties": {
            "groupId": {
              "type": "string",
              "description": "Group ID for this provider configuration"
            }
          }
        }
      }
    ]
  },
  "scripts": {
    "vsce:package": "pnpm exec vsce package --no-dependencies",
    "vsce:publish": "pnpm exec vsce publish --no-dependencies",
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "lodash.kebabcase": "^4.1.1",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/lodash.kebabcase": "^4.1.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}